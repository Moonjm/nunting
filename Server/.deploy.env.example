# Raspberry Pi SSH 설정 — .deploy.env 에 복사해서 채우세요.
# .deploy.env 는 .gitignore 됨 (실제 호스트/도메인 노출 금지).

# Pi 의 SSH 사용자.
REMOTE_USER=pi

# Pi 의 hostname 또는 IP. mDNS 가 동작하면 pi.local, 아니면 LAN IP (예: 192.168.0.15).
REMOTE_HOST=pi.local

# 배포 디렉토리 (Pi 상의 절대경로). 없으면 deploy.sh 가 mkdir 함.
# 첫 배포 전 .env 와 secrets/AuthKey_*.p8 를 이 디렉토리에 미리 두세요.
REMOTE_BASE_DIR=/home/pi/docker/nunting
