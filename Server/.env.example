# NuntingServer Docker compose 환경변수 템플릿.
# 사용법:
#   cp .env.example .env
#   # 본인 값으로 채운 후
#   docker compose up -d --build
#
# 주의: .env 자체는 .gitignore 됨 — 실제 값은 commit 하지 말 것.

# === 외부 노출 ===
# 호스트 OS 가 외부에 노출할 포트. 라우터 포트포워딩 / Cloudflare 프록시는 이 포트를 가리킴.
# 컨테이너 내부 포트(8080) 는 docker-compose.yml 의 environment 블록에서 고정.
NUNTING_HOST_PORT=8080

# === DB (PostgreSQL) ===
# DB 는 같은 compose 의 nnt-postgres 컨테이너. host/port/name/user/sslmode 는
# docker-compose.yml 에 고정(host=nnt-postgres, name/user=nnt). .env 에선 아래 둘만 설정.
#
# DB password — Postgres 초기화(POSTGRES_PASSWORD)와 서버 접속이 같은 값을 쓴다.
NUNTING_DB_PASSWORD=changeme
# Postgres 를 호스트(Pi)에 노출할 외부 포트 — DBeaver/psql 직접 접속용.
# 서버↔DB 내부 통신과는 무관(그건 compose 네트워크 5432). 다른 PG 와 충돌하면 바꾼다.
NUNTING_DB_HOST_PORT=5432
#
# 컨테이너가 아니라 로컬에서 직접 서버/테스트를 돌릴 때만 host 를 덮어쓴다:
#   NUNTING_DB_HOST=localhost   # 그 외 NUNTING_DB_PORT 등도 필요시
# 테스트는 NUNTING_TEST_DATABASE_URL 로 로컬 PG 를 가리킨다(미설정 시 관련 테스트 skip).

# === 폴링 주기 ===
# 뽐뿌 모바일 리스트 폴링 간격(초). 기본 180. 60 이하로 줄이면 사이트 부담 + APNs 노이즈.
NUNTING_POLL_INTERVAL_SECONDS=180

# === APNs (개발/sandbox 기준) ===
# 컨테이너 안에서 본 .p8 파일 경로. ./secrets 가 /run/secrets 로 mount 되므로
# `/run/secrets/<파일명>` 형태로 적는다. 호스트 경로(./secrets/...) 아님.
APNS_KEY_PATH=/run/secrets/AuthKey_XXXXXXXXXX.p8

# Apple Developer Portal → Keys 에서 발급받은 Key ID / Team ID.
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=XXXXXXXXXX

# iOS 앱 번들 ID.
APNS_TOPIC=com.moonjm.nunting

# sandbox: api.sandbox.push.apple.com (development 빌드/사이드로드)
# prod:    api.push.apple.com         (App Store 배포 — 1인 도구라 sandbox 유지)
APNS_HOST=api.sandbox.push.apple.com

# === MetricKit admin 뷰 (선택) ===
# GET /admin/metrics?key=<값> 의 ?key 검증용 약한 비밀. 비워두면 admin 뷰 비활성(404).
# 앱이 올린 MetricKit payload(종료 사유/크래시)를 브라우저로 바로 보려면 값 지정 후
#   https://<서버>/admin/metrics?key=<값>
# 배포 안 하는 1인 도구라 약한 비밀로 충분. 추측 어려운 임의 문자열 권장.
NUNTING_ADMIN_KEY=

# === 로그 파일 (선택) ===
# 비워두면 stdout 만(Docker json-file). 값 지정 시 stdout + 디렉토리 안 날짜별 파일.
#   파일명: nunting-YYYY-MM-DD.log
#   회전: 날짜 바뀔 때 자동으로 새 파일.
#   retention: NUNTING_LOG_RETENTION_DAYS 일 이전 파일 자동 삭제 (기본 30, 0 이하면 보존).
# 컨테이너 내부 경로 — docker-compose.yml 의 ./logs:/var/log/nunting 볼륨 안.
NUNTING_LOG_DIR=/var/log/nunting
NUNTING_LOG_RETENTION_DAYS=30
